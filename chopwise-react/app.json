      "googleIosClientId": "386696108600-relg6n41v8jtpslfrunin108rojgm56a.apps.googleusercontent.com",
      "googleWebClientId": "386696108600-ksi4fbg3ltpguf5kspkc9lbua6d0knru.apps.googleusercontent.com"
    }
  }
}
