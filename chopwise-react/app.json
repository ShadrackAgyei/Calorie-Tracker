{
  "expo": {
    "name": "ChopWise",
    "slug": "chopwise",
    "version": "1.0.0",
    "scheme": "chopwise",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#007A3D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chopwise.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#007A3D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.chopwise.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FoodieGh to access your camera to scan your meals."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FoodieGh to access your photos to log meals."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supabaseUrl": "https://jnmrrksubjqrhnlbcatb.supabase.co",
